# Patches must survive verbatim - a CRLF checkout on Windows makes `git apply`
# fail against the LF-normalised MeshCore sources.
*.patch -text

# Keep tooling LF everywhere so the same scripts run on CI and on Windows.
*.py    text eol=lf
*.sh    text eol=lf
*.yml   text eol=lf
*.ini   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.html  text eol=lf

# Firmware images are binary.
*.uf2 binary
*.bin binary
*.hex binary
