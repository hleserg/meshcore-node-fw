diff --git a/examples/companion_radio/main.cpp b/examples/companion_radio/main.cpp
index ef9b6bfc..1c8e39d8 100644
--- a/examples/companion_radio/main.cpp
+++ b/examples/companion_radio/main.cpp
@@ -47,7 +47,12 @@ static uint32_t _atoi(const char* sp) {
   #elif defined(SERIAL_RX)
     #include <helpers/ArduinoSerialInterface.h>
     ArduinoSerialInterface serial_interface;
-    HardwareSerial companion_serial(1);
+    // UART1 is claimed by the GPS (EnvironmentSensorManager uses Serial1), so let
+    // the board pick a free UART peripheral with -D COMPANION_SERIAL_NUM=n.
+    #ifndef COMPANION_SERIAL_NUM
+      #define COMPANION_SERIAL_NUM 1
+    #endif
+    HardwareSerial companion_serial(COMPANION_SERIAL_NUM);
   #else
     #include <helpers/ArduinoSerialInterface.h>
     ArduinoSerialInterface serial_interface;
@@ -74,6 +79,15 @@ static uint32_t _atoi(const char* sp) {
   #ifdef BLE_PIN_CODE
     #include <helpers/nrf52/SerialBLEInterface.h>
     SerialBLEInterface serial_interface;
+  #elif defined(SERIAL_RX)
+    #include <helpers/ArduinoSerialInterface.h>
+    ArduinoSerialInterface serial_interface;
+    // Companion protocol on a hardware UART instead of USB-CDC.
+    // Serial1 is NRF_UARTE0 and on most variants is wired to the GPS, so default
+    // to Serial2 (NRF_UARTE1). Override with -D COMPANION_SERIAL=SerialX.
+    #ifndef COMPANION_SERIAL
+      #define COMPANION_SERIAL Serial2
+    #endif
   #else
     #include <helpers/ArduinoSerialInterface.h>
     ArduinoSerialInterface serial_interface;
@@ -85,6 +99,39 @@ static uint32_t _atoi(const char* sp) {
   #error "need to define a serial interface"
 #endif
 
+#if defined(SERIAL_RX)
+  // Report the companion UART assignment over USB-CDC at boot. On nRF52 the
+  // Arduino pin number is an index into g_ADigitalPinMap, so the silkscreen
+  // label, the Arduino number and the actual port pin can all disagree - print
+  // the resolved port pin rather than the number we were handed.
+  #define _MC_STR2(x) #x
+  #define _MC_STR(x) _MC_STR2(x)
+
+  static void printCompanionSerialBanner() {
+    uint32_t t0 = millis();
+    while (!Serial && millis() - t0 < 1500) { delay(10); }  // let the host attach
+
+    Serial.println();
+    Serial.println("=== MeshCore companion :: hardware UART ===");
+    Serial.printf("firmware  : %s (%s)\n", FIRMWARE_VERSION, FIRMWARE_BUILD_DATE);
+  #if defined(NRF52_PLATFORM)
+    Serial.printf("port      : %s (NRF_UARTE)\n", _MC_STR(COMPANION_SERIAL));
+    uint32_t rx = g_ADigitalPinMap[SERIAL_RX], tx = g_ADigitalPinMap[SERIAL_TX];
+    Serial.printf("RX        : arduino %d -> P%d.%02d\n", SERIAL_RX, rx / 32, rx % 32);
+    Serial.printf("TX        : arduino %d -> P%d.%02d\n", SERIAL_TX, tx / 32, tx % 32);
+  #else
+    Serial.printf("port      : UART%s\n", _MC_STR(COMPANION_SERIAL_NUM));
+    Serial.printf("RX        : GPIO%d\n", SERIAL_RX);
+    Serial.printf("TX        : GPIO%d\n", SERIAL_TX);
+  #endif
+    Serial.println("baud      : 115200 8N1");
+    Serial.println("wiring    : board RX <- adapter TX, board TX -> adapter RX, GND <-> GND");
+    Serial.println("note      : companion protocol is on the UART above, NOT on this USB port");
+    Serial.println("==========================================");
+    Serial.flush();
+  }
+#endif
+
 /* GLOBAL OBJECTS */
 #ifdef DISPLAY_CLASS
   #include "UITask.h"
@@ -158,6 +205,10 @@ void setup() {
 
 #ifdef BLE_PIN_CODE
   serial_interface.begin(BLE_NAME_PREFIX, the_mesh.getNodePrefs()->node_name, the_mesh.getBLEPin());
+#elif defined(NRF52_PLATFORM) && defined(SERIAL_RX)
+  COMPANION_SERIAL.setPins(SERIAL_RX, SERIAL_TX);
+  COMPANION_SERIAL.begin(115200);
+  serial_interface.begin(COMPANION_SERIAL);
 #else
   serial_interface.begin(Serial);
 #endif
@@ -239,6 +290,10 @@ void setup() {
   ui_task.begin(disp, &sensors, the_mesh.getNodePrefs());  // still want to pass this in as dependency, as prefs might be moved
 #endif
 
+#if defined(SERIAL_RX)
+  printCompanionSerialBanner();
+#endif
+
   board.onBootComplete();
 }
 
